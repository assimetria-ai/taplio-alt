# Database
DATABASE_URL="postgresql://user:password@localhost:5432/letterflow?schema=public"

# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Client URL
CLIENT_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@letterflow.com
SMTP_FROM_NAME=LetterFlow

# Email Service (Alternative)
# SENDGRID_API_KEY=your-sendgrid-api-key
# MAILGUN_API_KEY=your-mailgun-api-key
# MAILGUN_DOMAIN=your-domain.com

# Analytics
TRACKING_DOMAIN=https://track.letterflow.com

# Rate Limiting
MAX_EMAILS_PER_HOUR=1000
MAX_SUBSCRIBERS_PER_LIST=50000
