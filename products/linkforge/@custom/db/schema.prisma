// products/linkforge/@custom/db/schema.prisma - LinkForge Database Schema
// Task #10311 - Custom Short Domain Configuration
// Task #10314 - Bulk link import via CSV (added title, tags)

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Link {
  id            String   @id @default(cuid())
  slug          String   @unique
  targetUrl     String   @map("target_url")
  title         String?  // Link title/description
  tags          String[] @default([]) // Tags for organization
  userId        String?  @map("user_id")
  domainId      String?  @map("domain_id") // Link to custom domain
  clicks        Int      @default(0)
  passwordHash  String?  @map("password_hash") // bcrypt hash for password-protected links
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  customDomain        CustomDomain?        @relation(fields: [domainId], references: [id], onDelete: SetNull)
  clickEvents         ClickEvent[]
  passwordAttempts    PasswordAttempt[]

  @@index([slug])
  @@index([userId])
  @@index([domainId])
  @@map("links")
}

model PasswordAttempt {
  id        String   @id @default(cuid())
  linkId    String   @map("link_id")
  ipAddress String   @map("ip_address")
  success   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  link      Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([ipAddress, createdAt])
  @@map("password_attempts")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  links         Link[]
  customDomains CustomDomain[]
  bioPages      BioPage[]

  @@map("users")
}

model CustomDomain {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  domain            String    @unique // e.g., "go.brand.com"
  status            String    @default("pending") // pending, verified, active, failed
  
  // DNS Verification
  verificationToken String    @map("verification_token") // Random token for DNS TXT record
  verifiedAt        DateTime? @map("verified_at")
  lastCheckedAt     DateTime? @map("last_checked_at")
  
  // SSL Configuration
  sslStatus         String    @default("pending") @map("ssl_status") // pending, active, failed
  sslProvider       String?   @map("ssl_provider") // letsencrypt, cloudflare, custom
  sslExpiresAt      DateTime? @map("ssl_expires_at")
  
  // Settings
  isDefault         Boolean   @default(false) @map("is_default") // Default domain for user's links
  redirectHttps     Boolean   @default(true) @map("redirect_https")
  
  // Metadata
  metadata          Json?     @default("{}") // Store additional config (CDN, etc.)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  links             Link[]

  @@index([userId])
  @@index([status])
  @@index([domain])
  @@map("custom_domains")
}

model BioPage {
  id          String    @id @default(cuid())
  username    String    @unique // URL slug: /bio/username
  title       String    // Display name
  description String?   // Bio description
  avatarUrl   String?   @map("avatar_url")
  theme       String    @default("default") // Theme name
  bgColor     String    @default("#ffffff") @map("bg_color")
  textColor   String    @default("#000000") @map("text_color")
  buttonStyle String    @default("rounded") @map("button_style") // rounded, pill, square
  userId      String    @map("user_id")
  isPublished Boolean   @default(true) @map("is_published")
  views       Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bioLinks  BioLink[]

  @@index([userId])
  @@index([username])
  @@map("bio_pages")
}

model BioLink {
  id        String   @id @default(cuid())
  bioPageId String   @map("bio_page_id")
  label     String   // Button text
  url       String   // Target URL
  icon      String?  // Icon name (optional)
  position  Int      @default(0) // Sort order
  isActive  Boolean  @default(true) @map("is_active")
  clicks    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  bioPage   BioPage  @relation(fields: [bioPageId], references: [id], onDelete: Cascade)

  @@index([bioPageId])
  @@map("bio_links")
}

model ClickEvent {
  id         String   @id @default(cuid())
  linkId     String   @map("link_id")
  userAgent  String?  @map("user_agent")
  referer    String?
  ipAddress  String?  @map("ip_address")
  country    String?
  city       String?
  isConversion Boolean @default(false) @map("is_conversion")
  conversionType String? @map("conversion_type")
  conversionValue Float? @map("conversion_value")
  metadata   Json?    @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  link       Link     @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([createdAt])
  @@index([isConversion])
  @@map("click_events")
}
