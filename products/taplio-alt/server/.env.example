# Application Environment
NODE_ENV=development

# Frontend URL (used for CORS)
APP_URL=http://localhost:5173

# CORS Development Origins (task #8278)
# Comma-separated list of allowed localhost origins for development
# Only used when NODE_ENV !== 'production'
# Default: http://localhost:5173,http://localhost:3000,http://localhost:3001,http://localhost:3005,http://127.0.0.1:3001,http://127.0.0.1:3000,http://127.0.0.1:5173
# CORS_DEV_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT=30000
# DB_POOL_CONNECTION_TIMEOUT=2000
# DB_POOL_SSL=false

# Production allowed origins (required in production, comma-separated)
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
# CORS_ALLOWED_ORIGINS=

# Trust proxy — set to 'false' only when NOT behind a reverse proxy (nginx, ALB, Caddy, etc.)
# When enabled (default), Express trusts X-Forwarded-For for real client IP detection.
# Required for correct rate limiting and IP-based security behind a load balancer.
# TRUST_PROXY=false

# Auth (RS256 asymmetric key pair)
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste PEM content with literal \n line endings (no actual newlines in the .env value)
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEowIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG...\n-----END PUBLIC KEY-----"

# Session Secret (change in production!)
SESSION_SECRET=your-secret-key-change-in-production

# CSRF Secret — used to HMAC-sign CSRF nonce cookies (≥ 32 random bytes in hex)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If unset, a new random secret is generated on each server start (invalidates tokens on restart).
# CSRF_SECRET=

# Stripe Configuration
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Email ────────────────────────────────────────────────────────────────────
# Provider is auto-detected from env vars (SES → SMTP → console fallback).
# Set EMAIL_PROVIDER explicitly to force a specific provider.
# EMAIL_PROVIDER=smtp

# Sender address used for all outgoing emails
# EMAIL_FROM="My App <noreply@example.com>"

# App display name used in email subjects and templates
# APP_NAME=MyApp

# SMTP (Resend, SendGrid, Mailgun, Postmark, self-hosted, etc.)
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_your_api_key_here
# SMTP_SECURE=false           # true forces TLS (port 465); false uses STARTTLS (port 587)

# Amazon SES
# SES_FROM_EMAIL=noreply@example.com
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Logging ─────────────────────────────────────────────────────────────────
# Structured log level: trace | debug | info | warn | error | fatal
# Default: debug in development, info in production
# LOG_LEVEL=info

# In-memory ring buffer size — number of recent log entries kept for /api/logs
# Default: 500
# LOG_BUFFER_SIZE=500

# Service name attached to every log line
# SERVICE_NAME=server

# ─── File Storage ─────────────────────────────────────────────────────────────
# Without S3 config, files are stored locally in ./uploads (development only).
# Configure S3 (or MinIO / LocalStack) for production.

# S3_BUCKET=my-app-uploads
# S3_ENDPOINT=http://localhost:9000   # MinIO or LocalStack; leave unset for real AWS S3
