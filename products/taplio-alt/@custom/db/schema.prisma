// Prisma Schema for Taplio-Alt
// Task #10266 - LinkedIn OAuth Token Storage

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model (simplified - extend as needed)
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  // Relations
  oauthTokens       OAuthToken[]
  posts             Post[]
  contentTemplates  ContentTemplate[]
  
  @@map("users")
}

// OAuth Token Storage
// Stores access tokens, refresh tokens, and profile data from OAuth providers
// Task #10273 - Enhanced with encryption support
model OAuthToken {
  id            String    @id @default(cuid())
  userId        String
  provider      String    // 'linkedin', 'twitter', etc.
  
  // Access token (encrypted)
  accessToken   String    @db.Text
  accessTokenIv String?   // Initialization vector for encryption
  accessTokenTag String?  // Auth tag for encryption validation
  
  // Refresh token (encrypted)
  refreshToken  String?   @db.Text
  refreshTokenIv String?  // Initialization vector for encryption
  refreshTokenTag String? // Auth tag for encryption validation
  
  expiresAt     DateTime? // When the access token expires
  scope         String    // Granted permissions
  tokenType     String    @default("Bearer")
  
  // LinkedIn profile data (JSON)
  profile       Json?     // Stores profile data from LinkedIn
  
  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Composite unique constraint
  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@map("oauth_tokens")
}

// Social Media Posts
// Tracks published content across platforms
model Post {
  id              String    @id @default(cuid())
  userId          String
  content         String    @db.Text
  scheduledFor    DateTime?
  publishedAt     DateTime?
  status          PostStatus @default(DRAFT)
  
  // LinkedIn-specific data
  linkedinPostId  String?   // LinkedIn post URN
  linkedinUrl     String?   // Public URL to the post
  
  // Metadata
  mediaUrls       Json?     // Array of media URLs
  hashtags        String[]  // Array of hashtags
  mentions        String[]  // Array of mentioned profiles
  
  // Analytics
  impressions     Int       @default(0)
  likes           Int       @default(0)
  comments        Int       @default(0)
  shares          Int       @default(0)
  
  // Timestamps
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  metrics         PostMetrics?
  
  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
  @@index([publishedAt])
  @@map("posts")
}

// Post Engagement Metrics
// Tracks likes, comments, shares, impressions, and engagement rate per post
model PostMetrics {
  id              Int       @id @default(autoincrement())
  postId          String    @unique
  likes           Int       @default(0)
  comments        Int       @default(0)
  shares          Int       @default(0)
  impressions     Int       @default(0)
  engagementRate  Float     @default(0)
  recordedAt      DateTime  @default(now())
  createdAt       DateTime  @default(now())
  
  // Relations
  post            Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  
  @@index([recordedAt])
  @@map("post_metrics")
}

// Content Templates
// Pre-built and user-created templates for LinkedIn post formats
model ContentTemplate {
  id         String    @id @default(cuid())
  userId     String?
  name       String
  content    String    @db.Text
  category   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  // Relations
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([category])
  @@map("content_templates")
}

// Post Status Enum
enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

// API Usage Tracking (for rate limiting)
model ApiUsage {
  id            String    @id @default(cuid())
  userId        String
  provider      String    // 'linkedin'
  endpoint      String    // API endpoint called
  requestCount  Int       @default(1)
  date          DateTime  @default(now())
  
  @@unique([userId, provider, endpoint, date])
  @@index([userId, provider, date])
  @@map("api_usage")
}
