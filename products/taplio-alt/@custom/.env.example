# Taplio-Alt Environment Configuration
# Task #10273 - LinkedIn OAuth Connection Flow

# ===========================================
# LinkedIn OAuth Configuration
# ===========================================
# Get these from: https://www.linkedin.com/developers/apps

LINKEDIN_CLIENT_ID=your_client_id_here
LINKEDIN_CLIENT_SECRET=your_client_secret_here

# OAuth callback URL (must match LinkedIn app settings)
# Development: http://localhost:3000/api/oauth/linkedin/callback
# Production: https://yourdomain.com/api/oauth/linkedin/callback
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/oauth/linkedin/callback

# Redirect after successful OAuth (optional)
OAUTH_SUCCESS_REDIRECT=/dashboard/integrations?success=linkedin

# ===========================================
# Token Encryption (REQUIRED for production)
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This must be a 64-character hex string (32 bytes)
TOKEN_ENCRYPTION_KEY=

# ===========================================
# Database Configuration
# ===========================================
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/taplioalt

# ===========================================
# Session Configuration
# ===========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your_session_secret_here

# Session cookie settings
SESSION_SECURE=false  # Set to true in production (requires HTTPS)
SESSION_MAX_AGE=86400000  # 24 hours in milliseconds

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development  # development | production
PORT=3000
HOST=localhost

# ===========================================
# Security Settings
# ===========================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info  # debug | info | warn | error
LOG_FORMAT=json  # json | pretty

# ===========================================
# Optional: LinkedIn API Configuration
# ===========================================
# API request timeout (milliseconds)
LINKEDIN_API_TIMEOUT=10000

# Retry configuration
LINKEDIN_API_MAX_RETRIES=3
LINKEDIN_API_RETRY_DELAY=1000
